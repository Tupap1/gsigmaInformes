# Entorno de Pruebas (Test) — Base de Datos Docker Local
# Puerto 3309: el contenedor de desarrollo Docker

NODE_ENV=test
PORT=3002

# Base de Datos Docker (MySQL 5.5 en contenedor)
DB_HOST=127.0.0.1
DB_PORT=3309

# Pool Read-Only (usuario con solo SELECT)
DB_READ_USER=reci_read
DB_READ_PASSWORD=read_pass_123

# Pool Write (usuario con INSERT/UPDATE/DELETE en adm.trc y pv.proveedo)
DB_WRITE_USER=reci_write
DB_WRITE_PASSWORD=write_pass_123

# ID de empresa (dato de prueba)
DB_EMPID=000000000000001
